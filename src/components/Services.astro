---
const groups = [
  {
    title: "Ingeniería Eléctrica y Renovables",
    color: "bg-amber-50",
    borderColor: "border-amber-200",
    titleColor: "text-amber-700",
    iconColor: "text-amber-500",
    dotColor: "bg-amber-400",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    services: [
      "Proyectos eléctricos",
      "Instalaciones fotovoltaicas",
      "Puntos de carga de vehículos eléctricos",
      "Boletín eléctrico (CIE)",
      "Certificado de eficiencia energética (CEE)",
      "Auditoría de eficiencia energética",
    ]
  },
  {
    title: "Ingeniería para Industrias y Edificios",
    color: "bg-blue-50",
    borderColor: "border-blue-200",
    titleColor: "text-blue-700",
    iconColor: "text-blue-500",
    dotColor: "bg-blue-400",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><path d="M12 12v3M8 12v3M16 12v3"/></svg>`,
    services: [
      "Proyectos de instalaciones",
      "Proyectos de naves industriales",
      "Proyectos de ingeniería civil",
    ]
  },
  {
    title: "Topografía y Gestión de Suelos",
    color: "bg-emerald-50",
    borderColor: "border-emerald-200",
    titleColor: "text-emerald-700",
    iconColor: "text-emerald-500",
    dotColor: "bg-emerald-400",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>`,
    services: [
      "Estudios del terreno",
      "Medición de parcelas",
      "Deslindes",
      "Levantamiento topográfico",
    ]
  },
  {
    title: "Consultoría y Legalización",
    color: "bg-violet-50",
    borderColor: "border-violet-200",
    titleColor: "text-violet-700",
    iconColor: "text-violet-500",
    dotColor: "bg-violet-400",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    services: [
      "Servicios técnicos",
      "Gestiones ante industria",
    ]
  }
];
---

<section id="servicios" class="py-20 lg:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-4 py-1.5 bg-primary-100 text-primary-700 text-sm font-semibold rounded-full mb-4">Nuestros servicios</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-extrabold text-gray-900 mb-6">
        Soluciones de ingeniería <span class="text-primary-600">a tu medida</span>
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed">
        Ofrecemos un servicio integral de ingeniería tanto para <strong>empresas</strong> como para <strong>particulares</strong>. Desde certificados hasta instalaciones completas.
      </p>
    </div>

    <!-- Groups Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {groups.map((group) => (
        <div class={`rounded-2xl border ${group.borderColor} ${group.color} p-6 flex flex-col`}>
          <!-- Group Header -->
          <div class="flex items-start gap-3 mb-5">
            <div class={`flex-shrink-0 w-12 h-12 bg-white rounded-xl flex items-center justify-center shadow-sm ${group.iconColor}`}>
              <Fragment set:html={group.svg} />
            </div>
            <h3 class={`text-base font-heading font-bold ${group.titleColor} leading-snug pt-1`}>{group.title}</h3>
          </div>

          <!-- Service List -->
          <ul class="flex flex-col gap-2.5">
            {group.services.map((service) => (
              <li class="flex items-start gap-2.5 text-sm text-gray-700">
                <span class={`flex-shrink-0 w-1.5 h-1.5 rounded-full ${group.dotColor} mt-1.5`}></span>
                {service}
              </li>
            ))}
          </ul>

          <div class="mt-auto pt-5">
            <a href="#contacto" class={`inline-flex items-center text-sm font-semibold ${group.titleColor} hover:underline`}>
              Solicitar información
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-1">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12">
      <p class="text-gray-500 mb-4">¿No encuentras lo que buscas? Consúltanos sin compromiso</p>
      <a href="#contacto" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-all duration-200 shadow-md hover:shadow-lg">
        Contactar ahora
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 ml-2">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
